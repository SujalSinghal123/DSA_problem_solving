class Solution {
public:
    int longestConsecutive(vector<int>& nums) {

        set<int>st;
        int count =1;
        int ans =1;
        for ( int i=0;i<nums.size();i++){
            st.insert(nums[i]);
        }
        for ( auto it :st){
            if ( st.find(it-1)==st.end()){
                // int count =1;
                int x=it;                         //first elemts mil gya ab second check krr lenge 
                while (st.find(x+1)!=st.end()){
                    x=x+1;
                    count++;
                }
                ans =max(ans,count );

            }
        }
        return ans ;
