class Solution {
public:
    int smallestDivisor(vector<int>& nums, int threshold) {
        int i=1;
        int j=*max_element(nums.begin(),nums.end());
        while ( i<j){
            int mid= ( i+j)/2;
            int sum =0;
            for ( int x:nums){
                sum+=ceil(double(x)/mid);
                // sum +=ceil(r);
            }
            if ( sum<=threshold){
                j=mid;
            }
            else {
                i=mid+1;
            }
        }
        return i ;
    }
};
