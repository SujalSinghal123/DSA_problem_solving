class Solution {
public:
    vector<int> rearrangeArray(vector<int>& nums) {
        vector <int> vec1;
        vector <int> vec2;

        for ( int i=0;i<nums.size();i++){
            if ( nums[i]>=0){
            vec1.push_back(nums[i]);
        }

        else {
            vec2.push_back(nums[i]);
        }
    }

    vector <int> vec3;
    int i=0;
    int j=0;
    while ( i<vec1.size()&&j<vec2.size()){
        vec3.push_back(vec1[i++]);
        vec3.push_back(vec2[j++]);
    }

    return vec3;

    }
};
