class Solution {
public:
    int minEatingSpeed(vector<int>& piles, int h) {
        int i=1;
        int j=*max_element(piles.begin(),piles.end());
        // int min=INT_MAX;
        while ( i<j){
            int mid =( i+j)/2;
            int  hours =0;
            for ( int p: piles){
                hours+=ceil(double(p)/mid);    //( p+ mid-1)/mid y kro to or accha h 
            }
            if ( hours<=h){
                j=mid;
            }
            else {
                i=mid+1;
            }
        }
        return i;
    }  
};
