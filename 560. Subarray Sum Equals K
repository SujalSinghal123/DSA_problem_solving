class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        // int count =0;
        // // vector <int> vec;

        // for ( int j=0;j<nums.size();j++){
        //     int sum=0;
        // for ( int i=j;i<nums.size();i++){
        //     sum +=nums[i];
        //     if (sum==k){
        //         count ++;

        //     }
        // }
        // }
        // return count ;

        unordered_map <int,int> mp;
        mp[0]=1;
        int sum =0,count =0;
        for ( int i=0;i<nums.size();i++){
            sum+=nums[i];
            if ( mp.find (sum-k)!=mp.end()){
                count+=mp[sum-k];
            }
            mp[sum]++;
        }
        return count;

    }
};
