class Solution {
public:
    void nextPermutation(vector<int>& nums) {
        // next_permutation(nums.begin(),nums.end());
        // return ;


        int ind =-1;
        for ( int i=nums.size()-2;i>=0;i--){
            if ( nums[i]<nums[i+1]){//////////////////chenge krek bda elemets ko layemge 
                ind=i;
                break;
            }
        }
        if ( ind ==-1){
            reverse ( nums.begin(),nums.end ());/////////agr ind nhi mila to 
            return ;
        }
        for ( int i=nums.size()-1;i>=ind;i--){
            if ( nums[i]>nums[ind]){//////////////////////swap 
                swap ( nums[i],nums[ind]);
                break ;
            }
        }
        reverse( nums.begin()+ind +1,nums.end());//////////last m bacje hue elemegts ko return krr dnege 
        return;
    }
};
