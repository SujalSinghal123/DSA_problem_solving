class Solution {
public:
    int search(vector<int>& nums, int target) {
        // int ans ;
        // for ( int i=0;i<nums.size();i++){
        //     if ( nums[i]==target){
        //         return i;
                
        //         }
        // }///////////////////////////O(logn)
        // return -1;


        int i=0,j=nums.size()-1;
        while (i<=j){
            int mid =(i+j)/2;
            if ( nums[mid]==target){
                return mid ;

            }
            else if ( nums[mid]<target ){
                i=mid+1;
            }
            else {////////////////////s
                j=mid-1;
            }
        }
        return -1;
    }
};
