class Solution {
public:
    int findPeakElement(vector<int>& nums) {
        int i=0;
        int j=nums.size()-1;
        int ans =0;
        while ( i<j){
            int mid =(i+j)/2;
            if ( nums[mid]<nums[mid+1]){
                i=mid+1;
                // return mid ;  // y mhi lgana h 

            }
            else {
                j=mid;
            }
        }
        return i;
    }
};
