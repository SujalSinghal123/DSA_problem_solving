class Solution {
public:
    int findKthPositive(vector<int>& arr, int k) {
        // int missing = 0;
        // int current = 1;
        // int i = 0;

        // while (missing < k) {
        //     if (i < arr.size() && arr[i] == current) {
        //         i++;
        //     } else {
        //         missing++;
        //         if (missing == k) return current;
        //     }
        //     current++;
        // }
        // return current;

        int low = 0, high = arr.size() - 1;

        while (low <= high) {
            int mid = (low + high) / 2;

            int missing = arr[mid] - (mid + 1);

            if (missing < k)
                low = mid + 1;
            else
                high = mid - 1;
        }

        return low + k;
    }
};
