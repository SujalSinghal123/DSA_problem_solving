class Solution {
public:
    int minDays(vector<int>& bloomDay, int m, int k) {
        if ( m>bloomDay.size()/k){
            return -1;
        }
        int i=*min_element(bloomDay.begin(),bloomDay.end());
        int j=*max_element(bloomDay.begin(),bloomDay.end());
        // int  count =0;
        while ( i<j){
            int mid = (i+j)/2;
            int bouq=0,count =0;
            for ( int x:bloomDay){
                if ( x<=mid){
                    count ++;///////////phle count mid se chote dyas 
                }
                    else {
                        count =0;
                    }
                if ( count ==k){
                    bouq++;////////agr count ho jaye flowers jitne to bouq + kr denge 
                    count =0;
                }
            }
            if ( bouq>=m){
                j=mid;////////////////agr bouw bhi ho haye m jitne to high point ko mid krr dege kyui hme smallest chaiuye 
            }
            else {
                i=mid+1;
            }
        }
        return j;
    }
};
